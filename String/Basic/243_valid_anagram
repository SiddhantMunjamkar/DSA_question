#include <bits/stdc++.h>

using namespace std;

class Solution
{
public:
    bool isAnagram(string s, string t)
    {
        int freq[26] = {0};
        for (char c : s)
            freq[c - 'a']++;
        for (char c : t)
            freq[c - 'a']--;
        for (int i = 0; i < 26; i++)
        {
            if (freq[i] != 0)
            {
                return false;
            }
        }
        return true;
    }
};

int main()
{
        Solution sol;
        string s = "anagram", t = "nagaram";
        cout << (sol.isAnagram(s, t) ? "True" : "False") << endl;

    return 0;
}